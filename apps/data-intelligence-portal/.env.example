# Copy to .env and adjust. All values are optional — the portal runs fully
# without any of them (AI answers fall back to a deterministic local responder).

# --- AI answers (optional) ---------------------------------------------------
# Provider priority: Anthropic (native) -> OpenAI-compatible -> deterministic.
# Leave all keys unset to use the built-in deterministic local responder.

# Native Claude/Anthropic (preferred). Requires `anthropic` (in requirements).
# Get a key at https://console.anthropic.com/ . Defaults to claude-opus-4-8.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Any OpenAI-compatible Chat Completions endpoint works (OpenAI, Azure OpenAI,
# Together, Groq, OpenRouter, a local Ollama/LM Studio server, etc.).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Paths (optional) --------------------------------------------------------
# Override only if you relocate the data or run from a different working dir.
# PORTAL_HOME=/app
# PORTAL_DB=/app/data/portal.db
# PORTAL_OBJECT_STORE=/app/data/object-store
