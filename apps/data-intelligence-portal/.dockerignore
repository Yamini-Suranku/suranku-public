# Keep the image lean and free of local/runtime state
.git
.github
.gitignore
.dockerignore
.pytest_cache
**/__pycache__
*.pyc
.venv
.env

# Runtime data is created on first run — never bake local state into the image
data/*.db
data/object-store/*
!data/object-store/.gitkeep

# Tests and docs aren't needed at runtime
tests
*.md
